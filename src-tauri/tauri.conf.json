{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "sekaitext",
  "version": "0.1.4",
  "identifier": "com.is14w.sekaitext",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "node scripts/build-go.mjs && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SekaiText",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/sekaitext-backend"
    ],
    "resources": {
      "../backend/resources/images/": "resources/images/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {},
      "nsis": {}
    }
  }
}
