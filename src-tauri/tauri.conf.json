{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SekaiText Next",
  "version": "5.0.0",
  "identifier": "com.snowglow-aww.sekaitext-next",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "node scripts/build-go.mjs && node scripts/build-engine.mjs && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SekaiText Next",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg",
      "deb"
    ],
    "externalBin": [
      "binaries/sekaitext-backend"
    ],
    "resources": {
      "../backend/resources/images/": "resources/images/",
      "resources/engine/": "engine/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "engine.entitlements"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
